{
  "stryker-config": {
    "project": "Incursa.Platform.Postgres.csproj",
    "test-projects": [
      "Incursa.Platform.Postgres.Tests.csproj"
    ],
    "test-case-filter": "FullyQualifiedName~PostgresPublicApiContractTests|FullyQualifiedName~DatabaseSchemaDeploymentTests|FullyQualifiedName~ControlPlaneGlobalSchedulerTests",
    "reporters": [
      "progress",
      "html",
      "json"
    ],
    "thresholds": {
      "high": 70,
      "low": 45,
      "break": 45
    },
    "mutate": [
      "Outbox/PostgresOutboxOptionsValidator.cs",
      "Inbox/PostgresInboxOptionsValidator.cs",
      "Fanout/PostgresFanoutOptionsValidator.cs",
      "Scheduler/PostgresSchedulerOptionsValidator.cs",
      "PostgresPlatformServiceCollectionExtensions.cs"
    ]
  }
}
