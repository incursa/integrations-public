{
  "stryker-config": {
    "project": "Incursa.Platform.SqlServer.csproj",
    "test-projects": [
      "Incursa.Platform.SqlServer.Tests.csproj"
    ],
    "test-case-filter": "FullyQualifiedName~OptionsValidationTests|FullyQualifiedName~PlatformRegistrationTests|FullyQualifiedName~SqlPlatformRegistrationTests|FullyQualifiedName~DatabaseSchemaDeploymentTests",
    "reporters": [
      "progress",
      "html",
      "json"
    ],
    "thresholds": {
      "high": 70,
      "low": 45,
      "break": 45
    },
    "mutate": [
      "Outbox/SqlOutboxOptionsValidator.cs",
      "Inbox/SqlInboxOptionsValidator.cs",
      "Fanout/SqlFanoutOptionsValidator.cs",
      "Scheduler/SqlSchedulerOptionsValidator.cs",
      "SqlPlatformServiceCollectionExtensions.cs"
    ]
  }
}
